<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <TableLayout
        android:id="@+id/gr_capsalera"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:stretchColumns="16">

        <TableRow>
        <TextView
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="Num"
            android:paddingLeft="1dp"
            android:gravity="center_horizontal"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="70dp"
            android:layout_height="wrap_content"
            android:text="Jug"
            android:gravity="center_horizontal"
            android:paddingLeft="1dp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="Tirs 1"
            android:paddingLeft="1dp"
            android:gravity="center_horizontal"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:text="% 1"
            android:background="@color/verd_Llivia"
            android:paddingLeft="1dp"
            android:gravity="center_horizontal"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="Tirs 2"
            android:paddingLeft="1dp"
            android:gravity="center_horizontal"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:text="% 2"
            android:background="@color/verd_Llivia"
            android:paddingLeft="1dp"
            android:gravity="center_horizontal"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="Tirs 3"
            android:paddingLeft="1dp"
            android:gravity="center_horizontal"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:text="% 3"
            android:background="@color/verd_Llivia"
            android:paddingLeft="1dp"
            android:gravity="center_horizontal"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="42dp"
            android:layout_height="wrap_content"
            android:text="R.OFF"
            android:paddingLeft="1dp"
            android:gravity="center_horizontal"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="42dp"
            android:layout_height="wrap_content"
            android:text="R.DEF"
            android:background="@color/verd_Llivia"
            android:paddingLeft="1dp"
            android:gravity="center_horizontal"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="Taps"
            android:paddingLeft="1dp"
            android:gravity="center_horizontal"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="Assis"
            android:background="@color/verd_Llivia"
            android:paddingLeft="1dp"
            android:gravity="center_horizontal"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="Rob"
            android:paddingLeft="1dp"
            android:gravity="center_horizontal"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="Perd"
            android:background="@color/verd_Llivia"
            android:paddingLeft="1dp"
            android:gravity="center_horizontal"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="Faltes"
            android:paddingLeft="1dp"
            android:gravity="center_horizontal"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="Punts"
            android:background="@color/verd_Llivia"
            android:paddingLeft="1dp"
            android:gravity="center_horizontal"
            android:textStyle="bold"/>

        </TableRow>

    </TableLayout>


    <ListView
        android:id="@+id/lv_resum_estadistica"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="3dp"/>


</LinearLayout>